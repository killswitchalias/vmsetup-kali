#!/usr/bin/zsh
setopt prompt_subst
RED='%F{red}' # Bold Red
GREEN='%F{green}' # Bold Green
BLUE='%F{blue}' # Bold Blue
YELLOW='%F{yellow}' # Bold Yellow
PURPLE='%F{magenta}' # Bold Purple
CYAN='%F{cyan}' # Bold Cyan
NC='%f' # No Color (reset)
CROSSMARK="${RED}x${NC}" # UTF-8 crossmark (✗)
case "$TERM" in
	xterm-color) color_prompt=yes;;
esac
force_color_prompt=yes
if [ -n "$force_color_prompt" ]; then
	if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
		color_prompt=yes
	else
		color_prompt=
	fi
fi
parse_git_branch() {
	#git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/(\1)/'
	git rev-parse --abbrev-ref HEAD 2>/dev/null
}
parse_shell_level() {
	LIMIT=2
	SHELL_LEVEL_SECTION=""
	if [[ -v TMUX ]]; then
SHELL_LEVEL_SECTION="
├ ${GREEN}Tmux${NC}"
		LIMIT=$(( LIMIT + 1 ))
	fi
	if (( SHLVL >= LIMIT )); then
SHELL_LEVEL_SECTION="${SHELL_LEVEL_SECTION}
├ shell lvl: ${SHLVL}"
	fi
}
update_prompt_status() {
	EXIT_STATUS=$?
	if (( EXIT_STATUS != 0 )); then
ERROR_STATUS_INDICATOR="─${CROSSMARK} ${RED}Error status: $EXIT_STATUS${NC}
├"
	else
		ERROR_STATUS_INDICATOR=""
	fi
}
checkWidth() {
	local T_COLS=$(tput cols)
	local WIDTH_THRESHOLD=40
	if (( T_COLS < WIDTH_THRESHOLD )); then
		PROMPT_WIDTH_SHORT="TRUE"
	else
		PROMPT_WIDTH_SHORT="FALSE"
	fi
}
gitStatus() {
	GIT_BRANCH_STATUS=$(parse_git_branch)
	if [[ -n "$GIT_BRANCH_STATUS" ]]; then
		if [[ "$PROMPT_WIDTH_SHORT" == "TRUE" ]]; then
local PREFIX="
├ "
		else
			local PREFIX=" ── "
		fi

		# Get counts
        staged_count=$(git status --porcelain | grep -c '^[AMDRC] ')
        unstaged_count=$(git status --porcelain | grep -c '^ M\|^ D')
        untracked_count=$(git status --porcelain | grep -c '^??')
        total_changes=$((staged_count + unstaged_count + untracked_count))

        UP_TO_DATE_COLOR="${YELLOW}"

        # Check if there are any changes to display
        if [[ $total_changes -eq 0 ]]; then
 			if git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then # If no file changes, check for status compared to origin
                LOCAL_HASH=$(git rev-parse @)
                REMOTE_HASH=$(git rev-parse @{u})

                if [ "$LOCAL_HASH" = "$REMOTE_HASH" ]; then
                    # Local and Remote hashes are the same
                    UP_TO_DATE_COLOR="${GREEN}"
                elif git merge-base --is-ancestor @{u} @; then
                    # Remote is an ancestor of local (Local is ahead)
                    UP_TO_DATE_COLOR="${YELLOW}"
                elif git merge-base --is-ancestor @ @{u}; then
                    # Local is an ancestor of remote (Local is behind)
                    UP_TO_DATE_COLOR="${YELLOW}"
                else
                    # No direct ancestor relationship (Diverged/Need merge)
                    UP_TO_DATE_COLOR="${RED}"
                fi
            else
                # No remote tracking branch is set up (e.g., brand new branch)
                UP_TO_DATE_COLOR="${BLUE}"
            fi
        fi
	

		GIT_SECTION="${PREFIX}git ${UP_TO_DATE_COLOR}(${GIT_BRANCH_STATUS}"

        if [[ $total_changes -gt 0 ]]; then
            # Build the status string: (branch-name S:1 U:2 ?:3)
            if [[ $staged_count -gt 0 ]]; then
                GIT_SECTION+=" ${GREEN}S:$staged_count"
            fi
            if [[ $unstaged_count -gt 0 ]]; then
                GIT_SECTION+=" ${RED}U:$unstaged_count"
            fi
            if [[ $untracked_count -gt 0 ]]; then
                GIT_SECTION+=" ${YELLOW}?:$untracked_count"
            fi
        fi
        GIT_SECTION+="${UP_TO_DATE_COLOR})${NC}"
	else
		GIT_SECTION=""
	fi
}
venvStatus() {
	if [[ -n "$VIRTUAL_ENV" ]]; then
		local VENV_NAME=$(basename $VIRTUAL_ENV)
VENV_SECTION="
├ venv (${VENV_NAME})"
	else
		VENV_SECTION=""
	fi
}
setUserColor() {
	if (( EUID == 0 )); then
		TIMECOLOR=$CYAN
		PWDCOLOR=$CYAN
		PROMPTCOLOR=$RED
	else
		TIMECOLOR=$PURPLE
		PWDCOLOR=$BLUE
		PROMPTCOLOR=$BLUE
	fi
}
generatePromptBody() {
	if [[ "$PROMPT_WIDTH_SHORT" == "TRUE" ]]; then
PROMPT_BODY="
├ ${TIMECOLOR}%D{%H:%M:%S}${NC}${GIT_SECTION}${VENV_SECTION}
├ ${PWDCOLOR}%c${NC}${SHELL_LEVEL_SECTION}"
	else
PROMPT_BODY=" ── ${TIMECOLOR}%D{%H:%M:%S}${NC}${GIT_SECTION}${VENV_SECTION}
├ ${PWDCOLOR}%~${NC}${SHELL_LEVEL_SECTION}"
	fi
}
precmd() {
	update_prompt_status
	setUserColor
	checkWidth
	parse_shell_level
	gitStatus
	venvStatus
	generatePromptBody
PROMPT="╭${ERROR_STATUS_INDICATOR}─ ${BLUE}%n${NC}㉿%m${PROMPT_BODY}
╰─${PROMPTCOLOR}\$${NC} "
}
